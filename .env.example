# sqlite (default) | postgres
DB_DRIVER=sqlite
SQLITE_PATH=./data/securecrm.sqlite

# PostgreSQL (when DB_DRIVER=postgres)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/securecrm

# Auth
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_DAYS=14

# Bootstrap admin (created on first run if no users exist)
BOOTSTRAP_ORG_NAME=Cyborg Group
BOOTSTRAP_ORG_SLUG=cyborg
BOOTSTRAP_ADMIN_EMAIL=louis@cyborggroup.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMeNow!23
BOOTSTRAP_ADMIN_NAME=Louis

# Magic-link email (SendGrid). Without this, links are logged server-side in production.
SENDGRID_API_KEY=
MAIL_FROM=noreply@cyborgwales.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SecureCRM

# Chrome extension — Add to Chrome (Chrome Web Store listing)
# After publishing (unlisted is fine), set these so /extension shows one-click install.
# NEXT_PUBLIC_CHROME_EXTENSION_STORE_URL=https://chrome.google.com/webstore/detail/kinetic-lead-capture/xxxxxxxx
# NEXT_PUBLIC_CHROME_EXTENSION_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
